# Fixed-snapshot prototype does not require secrets.
# Future live collectors or LLM analyzers should read keys from environment variables.
GITHUB_TOKEN=
OPENAI_API_KEY=

OPENAI_API_BASE=https://gms.ssafy.io/gmsapi/api.openai.com/v1
AGENTTRACE_SUMMARY_MODEL=gpt-4o-mini
AGENTTRACE_ANALYSIS_MODEL=gpt-4o-mini

AGENTTRACE_EMBEDDING_MODEL=text-embedding-3-small
AGENTTRACE_OPENAI_API_KEY=
AGENTTRACE_OPENAI_API_BASE=https://api.openai.com/v1

# LangSmith tracing for LangChain calls.
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT="AgentHub"

# Repo Ingest Configuration for Local/Remote Gitingest
AGENTTRACE_REPO_INGEST_BASE_URL=https://gitingest.com
AGENTTRACE_REPO_INGEST_HOST_HEADER=
AGENTTRACE_EXTERNAL_INGEST_ENABLED=false

# Finalize Analysis Model Settings (finalize_analysis 전용, evidence_evaluator와 독립)
# finalize_analysis 노드는 별도 factory(build_openai_finalize_model)를 사용함.
AGENTTRACE_FINALIZE_MODEL_TIMEOUT=90
AGENTTRACE_FINALIZE_MODEL_MAX_TOKENS=8192

# Evidence Evaluator Model: build_openai_analysis_model() 사용 (timeout 미설정, 장시간 허용)
# 실측 최대 161s — 위 timeout 설정이 evaluator에는 적용되지 않음 (회귀 방지)


